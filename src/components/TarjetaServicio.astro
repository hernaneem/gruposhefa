---
// ─────────────────────────────────────────────────────────────────────────────
//  TARJETA DE SERVICIO — GRUPO SHEFA
//  Tarjeta con ícono, título y resumen. Enlaza a la página del servicio.
// ─────────────────────────────────────────────────────────────────────────────

import Icono from './Icono.astro';
import { ruta } from '../lib/rutas.ts';

interface Props {
  slug: string;
  titulo: string;
  resumen: string;
  icono: string;
}
const { slug, titulo, resumen, icono } = Astro.props;
---

<a
  href={ruta(`servicios/${slug}`)}
  class="group flex h-full flex-col rounded-2xl border border-black/5 bg-white p-7 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-dorado/40 hover:shadow-md"
>
  <span
    class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-hueso text-verde transition-colors group-hover:bg-verde group-hover:text-dorado"
  >
    <Icono nombre={icono} class="h-6 w-6" />
  </span>
  <h3 class="font-titulo text-lg font-semibold text-verde-profundo">{titulo}</h3>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-tinta/70">{resumen}</p>
  <span
    class="mt-5 inline-flex items-center gap-1.5 font-titulo text-sm font-semibold text-verde transition-colors group-hover:text-dorado"
  >
    Conocer más
    <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
    </svg>
  </span>
</a>
