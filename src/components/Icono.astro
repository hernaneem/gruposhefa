    '<path d="M3 11a8 6 0 0 0 16 0c0-1-.3-2-.8-2.8"/><path d="M3 11c0-3.3 3.6-6 8-6 1.7 0 3.3.4 4.5 1.1"/><path d="M3 11v3a8 6 0 0 0 16 0v-3"/><circle cx="16" cy="6" r="2"/><path d="M7 12v.01"/>',
  atencion:
    '<path d="M21 11.5a8.5 8.5 0 0 1-12.3 7.6L3 21l1.9-5.7A8.5 8.5 0 1 1 21 11.5z"/><line x1="9" y1="11" x2="9" y2="11"/><line x1="12" y1="11" x2="12" y2="11"/><line x1="15" y1="11" x2="15" y2="11"/>',
  integral:
    '<rect x="3" y="3" width="8" height="8" rx="1"/><rect x="13" y="3" width="8" height="8" rx="1"/><rect x="3" y="13" width="8" height="8" rx="1"/><rect x="13" y="13" width="8" height="8" rx="1"/>',
};

const contenido = iconos[nombre] ?? iconos['estructura'];
---

<svg
  class={clase}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={contenido}
/>
