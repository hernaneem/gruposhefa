---
// ─────────────────────────────────────────────────────────────────────────────
//  ÍCONOS DE LÍNEA — GRUPO SHEFA
//  Íconos sencillos tipo "línea" que toman el color del texto (currentColor),
//  así puedes pintarlos de dorado, verde o blanco con clases de Tailwind.
//  Uso:  <Icono nombre="balanza" class="w-7 h-7 text-dorado" />
// ─────────────────────────────────────────────────────────────────────────────

interface Props {
  nombre: string;
  class?: string;
}

const { nombre, class: clase = 'w-7 h-7' } = Astro.props;

